# 1. M…ôrh…ôl…ô: Layih…ôni yńĪńümaq (Build)
FROM maven:3.8.5-openjdk-17 AS build
WORKDIR /app
COPY . .
# Maven-…ô deyirik ki, 'backend' qovluńüunun i√ßin…ô girib pom.xml-i ordan oxusun
RUN mvn -f backend/pom.xml clean package -DskipTests

# 2. M…ôrh…ôl…ô: Layih…ôni iŇü…ô salmaq (Run)
FROM eclipse-temurin:17-jdk-alpine
WORKDIR /app
# HazńĪr olan jar faylńĪnńĪ backend-in h…ôd…ôf qovluńüundan bura k√∂√ß√ľr√ľr√ľk
COPY --from=build /app/backend/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]