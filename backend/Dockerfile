# 1. M…ôrh…ôl…ô: Layih…ôni yƒ±ƒümaq (Build)
FROM maven:3.8.5-openjdk-17 AS build
WORKDIR /app
COPY . .
RUN mvn clean package -DskipTests

# 2. M…ôrh…ôl…ô: Layih…ôni i≈ü…ô salmaq (Run)
# Burada hamƒ± t…ôr…ôfind…ôn q…ôbul edil…ôn r…ôsmi Eclipse Temurin obrazƒ±ndan istifad…ô edirik
FROM eclipse-temurin:17-jdk-alpine
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]